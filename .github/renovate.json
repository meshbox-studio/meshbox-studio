{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "config:recommended",
    "customManagers:githubActionsVersions"
  ],
  "postUpdateOptions": [
    "gomodTidyE",
    "gomodMassage",
    "gomodUpdateImportPaths"
  ],
  "packageRules": [
    {
			"matchManagers": ["gomod"],
			"goGetDirs": ["github.com/meshbox-studio/meshbox-studio/ui/pages@none"],
			"postUpgradeTasks": {
				"commands": [
					"cd {{packageFileDir}} && install-tool golang 1.26",
					"cd {{packageFileDir}} && go mod tidy -e",
					"cd {{packageFileDir}} && go generate",
					"cd {{packageFileDir}} && go mod tidy"
				]
			}
		}
  ]
}
