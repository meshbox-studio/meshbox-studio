{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "config:recommended",
    "customManagers:githubActionsVersions"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "postUpgradeTasks": {
        "commands": [
          "go tool templ generate"
        ],
        "fileFilters": [
          "**/*.templ",
          "go.mod",
          "go.sum"
        ],
        "executionMode": "update"
      }
    }
  ]
}
